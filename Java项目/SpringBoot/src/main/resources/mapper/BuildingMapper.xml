<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.springboot.springboot.mapper.BuildingMapper">

    <!-- 查询楼栋，可根据楼栋编号模糊匹配，如果 number 为空或 null 则查询全部 -->
    <select id="findAllBuilding" resultType="com.springboot.springboot.pojo.Building" parameterType="java.lang.String">
        SELECT *
        FROM building
        <where>
            <if test="number != null and number != ''">
                building_code LIKE CONCAT('%', #{number}, '%')
            </if>
        </where>
    </select>

</mapper>
