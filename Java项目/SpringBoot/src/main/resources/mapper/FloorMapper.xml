<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.springboot.springboot.mapper.FloorMapper">

    <select id="findAllFloor" resultType="com.springboot.springboot.pojo.Floor">
        SELECT *
        FROM floor
        <where>
            <if test="number != null and number != ''">
                floor_number LIKE CONCAT('%', #{number}, '%')
            </if>
        </where>
    </select>

</mapper>
